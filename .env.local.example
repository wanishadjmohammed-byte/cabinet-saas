# Supabase — Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database — Get from: https://supabase.com/dashboard/project/_/settings/database
# Use the "Transaction" pooler connection string
DATABASE_URL=postgresql://postgres.xxx:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
